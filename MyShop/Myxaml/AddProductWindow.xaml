<Window x:Class="MyShop.Myxaml.AddProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyShop.Myxaml"
        mc:Ignorable="d"
        Title="AddProductWindow" Height="555" Width="888">
    <Window.Resources>

        <ResourceDictionary>
            <!--可以从Dictionary1.xaml中查找所有的key作为Command参数 -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/InterfaceParam.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.CommandBindings>
        <CommandBinding Command="{StaticResource AddProductWindow_Save}"
                     Executed="AddProductWindow_Save" />
        <CommandBinding Command="{StaticResource AddProductWindow_Cancel}"
              Executed="AddProductWindow_Cancel" />

    </Window.CommandBindings>
    <Grid Background="{StaticResource backColor1}">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" >
            <Label Content="基本信息:" FontSize="20" FontWeight="ExtraBlack"/>
            <Grid Margin="0,30,0,0"  >
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Label   Grid.Row="0" Grid.Column="0" Content="商品名称:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="0" Grid.Column="1" Content="货号/款号:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="0" Grid.Column="2" Content="商品类别:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="1" Grid.Column="0" Content="条码:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="1" Grid.Column="1" Content="单位:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="1" Grid.Column="2" Content="备注:" FontSize="13" FontWeight="ExtraBlack"/>
                <TextBox Name="AddProductWindow_txt_name" Grid.Row="0" Grid.Column="0"   Height="45" Margin="10,30,10,0"   Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_ItemNum" Grid.Row="0" Grid.Column="1"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_type" Grid.Row="0" Grid.Column="2"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_barcode" Grid.Row="1" Grid.Column="0"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_Unit" Grid.Row="1" Grid.Column="1"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_remark"  Grid.Row="1" Grid.Column="2"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
            </Grid>
        </Grid>
        <Grid Grid.Row="1" Background="{StaticResource backColor11}"/>
        <Grid Grid.Row="2">
            <Label Content="价格信息:" FontSize="20" FontWeight="ExtraBlack"/>
            <Grid Margin="0,30,0,0"  >


                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Label   Grid.Row="0" Grid.Column="0" Content="进货价:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="0" Grid.Column="1" Content="售货价:" FontSize="13" FontWeight="ExtraBlack"/>
                <Label   Grid.Row="0" Grid.Column="2" Content="会员价:" FontSize="13" FontWeight="ExtraBlack"/>
                <TextBox Name="AddProductWindow_txt_cost" Grid.Column="0"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_price" Grid.Column="1"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
                <TextBox Name="AddProductWindow_txt_price_Vip" Grid.Column="2"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>

            </Grid>
        </Grid>
        <Grid Grid.Row="3" Background="{StaticResource backColor11}"/>
        <Grid Grid.Row="4">
            <Label Content="数量:" FontSize="20" FontWeight="ExtraBlack"/>
            <Grid Margin="0,30,0,0"  >

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Label   Grid.Row="0" Grid.Column="0" Content="数量:" FontSize="13" FontWeight="ExtraBlack"/>
                <ComboBox  Name="AddProductWindow_txt_count" Grid.Column="0"   Height="45" Margin="10,30,10,0"  Style="{StaticResource TextBoxStyle1}"/>
               
            </Grid>
        </Grid>
        <Grid Grid.Row="5" Background="{StaticResource backColor11}"/>
        <Grid Grid.Row="6">

            <Grid Margin="0,0,0,0" Background="{StaticResource backColor11}" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Button Content="保存" Name="AddProductWindow_btn_save" Grid.Column="2" Command="{StaticResource AddProductWindow_Save}" Style="{StaticResource ButtonStyle2}" FontWeight="Bold" Margin="10,5,10,5"></Button>
                <Button Content="取消" Name="AddProductWindow_btn_cancel" Grid.Column="1"  Command="{StaticResource AddProductWindow_Cancel}"  Style="{StaticResource ButtonStyle2}" FontWeight="Bold" Background="{StaticResource backColor6 }" Margin="10,5,10,5"></Button>

            </Grid>
        </Grid>
    </Grid>
</Window>
